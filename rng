-- Safe remote fire (with fallback)
local function SafeFire(remote, data)
    local success, err = pcall(function()
        if type(data) == "string" then
            -- Try buffer.fromstring; if fails, send string
            local buf = buffer.fromstring(data)
            remote:FireServer(buf)
        else
            remote:FireServer(data)
        end
    end)
    if not success then
        pcall(function()
            remote:FireServer(data) -- fallback
        end)
    end
end

